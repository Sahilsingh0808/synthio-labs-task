# docker-compose variables. Copy to .env (repo root) and adjust.

# Host port mapping for the frontend (nginx inside the container listens on 80).
FRONTEND_PORT=5173

# Restrict published ports to this interface. Leave empty for 0.0.0.0 (all
# interfaces) — fine for local dev. On a public server with a host nginx
# terminating TLS, set to 127.0.0.1 so the compose ports are reachable only
# by the host nginx, not by the internet.
BIND_HOST=

# CORS origins the backend will accept. Keep localhost for dev; for a
# deployed stack set to your public origin (e.g. https://voiceslide.example.com)
# or "*" when the frontend and backend share an origin via the nginx proxy.
ALLOWED_ORIGINS=http://localhost:5173

# Build-time overrides for the frontend SPA. Leave empty to use same-origin
# URLs via the nginx proxy. Override if you deploy the frontend and backend
# on different domains.
VITE_API_BASE=
VITE_WS_BASE=

# --- HTTP Basic Auth (optional) ---
# Set both to gate the entire site behind a username + password. Leave either
# empty to run the site open (fine for trusted local networks). /healthz is
# always unauthenticated so container / load balancer health probes still work.
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
